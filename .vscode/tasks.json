{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "React Dev Server",
      "type": "shell",
      "command": "bash",
      "args": ["-c", "cd my-react-app && npm run dev"],
      "cwd": "${workspaceFolder}",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE.*ready in.*",
          "endsPattern": "^.*"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
